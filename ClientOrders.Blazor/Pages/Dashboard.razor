@page "/dashboard"
@inject AppDbContext Context
@using Microsoft.EntityFrameworkCore
@inject NavigationManager Nav
@inject IDashboardStatsService DashboardService




<MudButton Class="mb-4 nav-black"
            Variant="Variant.Text"
           StartIcon="@Icons.Material.Filled.ArrowBack"
           OnClick="GoBack">
    Return
</MudButton>

<MudGrid Class="mt-4">
         
    <MudItem xs="12" sm="4">
        <MudCard Class="pa-4">
            <MudText Typo="Typo.h6">Total Clients</MudText>
            <MudText Typo="Typo.h4">@totalClients</MudText>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="4">
        <MudCard Class="pa-4">
            <MudText Typo="Typo.h6">Total Orders</MudText>
            <MudText Typo="Typo.h4">@totalOrders</MudText>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="4">
        <MudCard Class="pa-4">
            <MudText Typo="Typo.h6">Orders This Month</MudText>
            <MudText Typo="Typo.h4">@ordersThisMonth</MudText>
        </MudCard>
    </MudItem>

    <MudItem xs="12">
        <MudChart ChartType="ChartType.Bar"
                  Labels="@labels"
                  Data="@data"
                  Width="100%"
                  Height="300px" />
    </MudItem>

</MudGrid>

@code {
   // private string[] labels = new[] { "Clients", "Orders" };
   /* private double[][] data = new double[][]
    {
        new double []{0,0}
    };*/
    private int totalClients;
    private int totalOrders;
    private int ordersThisMonth;
    private string[] labels = new[] { "Week 1", "Week 2", "Week 3", "Week 4" };

    private double[][] data = new double[][]
  {
    new double[] { 0, 0, 0, 0 }
  };
    protected override void OnInitialized()
    {


        var stats = DashboardService.GetStats();
        totalClients = stats.totalClients;
        totalOrders = stats.totalOrders;
        ordersThisMonth = stats.ordersThisMonth;


            /* data[0][0] = totalClients;
             data[0][1] = totalOrders;*/
            var weekly = DashboardService.GetOrdersPerWeek();
            for(int i = 0; i < 4; i++)
            {
                data[0][i] = weekly[i];
            }
    }
    private void GoBack()
    {
        Nav.NavigateTo("/clients");
    }
}
