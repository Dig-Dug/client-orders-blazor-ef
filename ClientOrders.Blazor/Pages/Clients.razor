<MudButton Variant="Variant.Filled"
             Color="Color.Primary"
             StartIcon="@Icons.Material.Filled.Add"
             OnClick="@(()=> Nav.NavigateTo("/clients/create"))"
>
Create Client
</MudButton>

<MudTextField @bind-Value="_searchString"
              Placeholder="Search clients..."
              Adornment="Adornment.Start"
              AdornmentIcon="@Icons.Material.Filled.Search"
              Class="mb-3" />


<MudTable T="Client"
          Items="clients"
          Filter="FilterFunc"
          Sortable="true"
          Hover="true"
          Dense="true">
    <HeaderContent>
        <MudTh>Image</MudTh>
        <MudTh @onclick="SortByName" Style="cursor:pointer" Class="sortable-header">Name</MudTh>
        <MudTh @onclick="SortByOrder" Style="cursor:pointer" Class="sortable-header">Orders</MudTh>
        <MudTh></MudTh>

    </HeaderContent>


<RowTemplate>
    <MudTd>
        <MudTooltip>
            <ChildContent>
                <MudAvatar Size="Size.Large" Style="cursor:pointer;">
                    @if (!string.IsNullOrWhiteSpace(context.ImageUrl))
                    {
                        <MudImage Src="@context.ImageUrl"
                                  ObjectFit="ObjectFit.Cover" />
                    }
                    else
                    {
                        @context.Name?.Substring(0, 1).ToUpper()
                    }
                </MudAvatar>
            </ChildContent>

            <TooltipContent>
                <MudPaper Class="pa-3" Elevation="4" Style="max-width:250px;">
                    <MudText Typo="Typo.subtitle1">
                        @context.Name
                    </MudText>

                    @if (!string.IsNullOrWhiteSpace(context.Description))
                    {
                        <MudText Typo="Typo.body2" Class="mt-1">
                            @context.Description
                        </MudText>
                    }

                    <MudDivider Class="my-2" />

                    <MudText Typo="Typo.caption">
                        Orders: @context.Orders.Count
                    </MudText>
                </MudPaper>
            </TooltipContent>
        </MudTooltip>
    </MudTd>

    <MudTd>@context.Name</MudTd>
    <MudTd>@context.Orders.Count</MudTd>

    <MudTd Align="Align.Right">
        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                       Color="Color.Primary"
                       OnClick="@(()=> Nav.NavigateTo($"clients/edit/{context.Id}"))" />
        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                       Color="Color.Error"
                       OnClick="@(() => ConfirmDelete(context.Id))" />
    </MudTd>
</RowTemplate>
</MudTable>



@code{
    private List<Client> clients = new();
    private string _searchString = "";
    private IEnumerable<Client> FilteredClients =>
    string.IsNullOrWhiteSpace(_searchString)
    ? clients : clients.Where(c =>
    c.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase));


    private bool _sortByNameAsync = true;
    private bool _sortByOrderAsync = true;
    protected override void OnInitialized()
    {
        clients = Context.Clients
            .Include(c => c.Orders)
            .ToList();
    }
    private async Task ConfirmDelete(int id){
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm", "Delete this client?"
        );
        if (!confirmed)
            return;

        var client = await Context.Clients.FindAsync(id);
        if (client is null)
            return;

        Context.Clients.Remove(client);
        await Context.SaveChangesAsync();
        clients.Remove(client);
    }

    private bool FilterFunc(Client client)
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        return client.Name.Contains(_searchString,
        StringComparison.OrdinalIgnoreCase);
    }

    private void SortByName()
    {
        if (_sortByNameAsync)
            clients = clients.OrderBy(c => c.Name).ToList();
        else
            clients = clients.OrderByDescending(c => c.Name).ToList();

        _sortByNameAsync = !_sortByNameAsync;
    }
    private void SortByOrder()
    {
        if (_sortByOrderAsync)
            clients = clients.OrderBy(c => c.Orders.Count).ToList();
        else
            clients = clients.OrderByDescending(c => c.Orders.Count).ToList();
        _sortByOrderAsync = !_sortByOrderAsync;
    }
}